# Database (MVP: local SQLite; production: switch to postgresql://...)
DATABASE_URL="file:./dev.db"

# LLM routing — mirrors SOVEREIGN-X connectors/llm_client.py
# Default: openclaw (GPT-5.5 via ChatGPT Plus OAuth, no API key needed)
# Override: deepseek
LLM_BACKEND=openclaw

# Optional override for openclaw binary path
# OPENCLAW_BIN=/opt/homebrew/bin/openclaw
# OPENCLAW_TIMEOUT_MS=120000

# DeepSeek (used as automatic fallback when OpenClaw fails)
DEEPSEEK_API_KEY=""
DEEPSEEK_MODEL=deepseek-chat

# OM Credit Ledger parameters (per spec §8)
OMC_INITIAL_USER_CREDITS=100
OMC_INTENT_SUBMISSION_COST=1
OMC_CAPABILITY_REWARD=10
OMC_PATTERN_CREATION_REWARD=5
OMC_PATTERN_REUSE_REWARD=2
