// OM World MVP — Prisma schema
// SQLite for local dev; switch DATABASE_URL to PostgreSQL for production.
// Schema mirrors spec §5 with native types adapted for SQLite (JSON→String, TEXT[]→String CSV).
// Future distributed-storage fields preserved (storage_uri, content_hash, future_distributed_storage).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Intent {
  id              String   @id
  originatorId    String?  @map("originator_id")
  intentText      String   @map("intent_text")
  context         String?
  desiredOutput   String?  @map("desired_output")
  budget          String?
  timeline        String?
  contact         String
  visibility      String   @default("public")
  intentType      String?  @map("intent_type")
  status          String   @default("submitted")
  constraintsJson String?  @map("constraints_json")
  matchedPathId   String?  @map("matched_path_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  paths      RealizationPath[]
  executions Execution[]

  @@index([intentType])
  @@index([status])
  @@map("intents")
}

model Capability {
  id                    String   @id
  providerId            String?  @map("provider_id")
  providerName          String   @map("provider_name")
  providerContact       String   @map("provider_contact")
  capabilityType        String   @map("capability_type") // Tool | Agent | Human Service
  name                  String
  description           String
  intentTypesSupported  String?  @map("intent_types_supported") // CSV
  inputSchemaJson       String?  @map("input_schema_json")
  outputSchemaJson      String?  @map("output_schema_json")
  inputRequired         String?  @map("input_required")
  outputProduced        String?  @map("output_produced")
  pricingModel          String?  @map("pricing_model") // free | fixed | usage_based | custom
  requiresLlm           Boolean  @default(false) @map("requires_llm")
  requiresApi           Boolean  @default(false) @map("requires_api")
  requiresHuman         Boolean  @default(false) @map("requires_human")
  status                String   @default("submitted")
  // Phase 3.5: capability testability (red-team #6). A capability that hasn't
  // been tested recently is excluded from matching, so the registry can't be
  // junk-filled with unreachable / broken / overstated tools.
  testInputJson         String?  @map("test_input_json")    // JSON-encoded fake intent fields for the test runner
  expectedShapeJson     String?  @map("expected_shape_json") // JSON-encoded shape of expected output (top-level keys)
  lastTestedAt          DateTime? @map("last_tested_at")
  testPassRate          Float?   @map("test_pass_rate")     // 0..1; null = never tested
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  @@index([capabilityType])
  @@index([status])
  @@index([lastTestedAt])
  @@map("capabilities")
}

model RealizationPath {
  id                       String   @id
  intentId                 String   @map("intent_id")
  recommendedCapabilities  String?  @map("recommended_capabilities") // CSV of capability ids
  estimatedCost            String?  @map("estimated_cost")
  estimatedTime            String?  @map("estimated_time")
  proofCondition           String?  @map("proof_condition")
  settlementTemplate       String?  @map("settlement_template")
  pathSummary              String?  @map("path_summary")
  // Phase 3.5: matching explainability (red-team #7). The Router is OM World's
  // first centralized power point; supply-side must be able to audit "why was
  // I not picked." Score ∈ [0,1]; alternativesJson lists the other 2-3 paths
  // the LLM considered + their scores + why-not reasons.
  matchScore               Float?   @map("match_score")
  alternativesJson         String?  @map("alternatives_json")
  routerVersion            String?  @map("router_version")
  status                   String   @default("proposed")
  createdAt                DateTime @default(now()) @map("created_at")
  updatedAt                DateTime @updatedAt @map("updated_at")

  intent     Intent      @relation(fields: [intentId], references: [id])
  executions Execution[]

  @@index([intentId])
  @@map("realization_paths")
}

model Execution {
  id              String   @id
  intentId        String   @map("intent_id")
  pathId          String?  @map("path_id")
  capabilityIds   String?  @map("capability_ids") // CSV
  nodeId          String?  @map("node_id") // future: which execution node ran this; MVP defaults to "local-dev"
  outputJson      String?  @map("output_json")
  outputText      String?  @map("output_text")
  traceJson       String?  @map("trace_json")
  cost            String?
  timeUsed        String?  @map("time_used")
  // Phase 3.5: numeric mirror of timeUsed for friction-curve math (red-team #1).
  // timeUsed is a human "57.2s" string; this is the raw seconds float.
  elapsedSec      Float?   @map("elapsed_sec")
  status          String   @default("submitted")
  // Phase 3.5: user feedback (red-team #10). null = unconfirmed; true = user
  // accepted the output as useful; false = explicitly rejected. Drives the
  // successfulReuseCount metric and gates pattern reuse rewards.
  userAccepted    Boolean? @map("user_accepted")
  feedbackAt      DateTime? @map("feedback_at")
  feedbackNote    String?  @map("feedback_note")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  intent Intent           @relation(fields: [intentId], references: [id])
  path   RealizationPath? @relation(fields: [pathId], references: [id])

  @@index([intentId])
  @@map("executions")
}

model Pattern {
  id                         String   @id
  creatorId                  String?  @map("creator_id")
  intentType                 String   @map("intent_type")
  patternName                String   @map("pattern_name")
  description                String?
  originalIntentId           String?  @map("original_intent_id")
  executionGraphJson         String?  @map("execution_graph_json")
  capabilitiesUsed           String?  @map("capabilities_used") // CSV
  historicalCost             String?  @map("historical_cost")
  historicalTime             String?  @map("historical_time")
  reuseCount                 Int      @default(0) @map("reuse_count")
  successCount               Int      @default(0) @map("success_count")
  failureCount               Int      @default(0) @map("failure_count")
  // Phase 3.5: reuse that actually reduced friction (red-team #8). Only
  // increments when adapted_time / fresh_avg_time < 0.85, OR when user
  // explicitly confirmed the output via PATCH /api/executions/[id]/feedback.
  // Rewards bind to this, not the raw reuseCount, so spam-reuse stops
  // generating OMC.
  successfulReuseCount       Int      @default(0) @map("successful_reuse_count")
  // Phase 3.5: cumulative timing for friction-curve dashboard. Updated on
  // every completion for the same intent_type.
  freshTimeSumSec            Float    @default(0) @map("fresh_time_sum_sec")
  freshExecutionCount        Int      @default(0) @map("fresh_execution_count")
  adaptedTimeSumSec          Float    @default(0) @map("adapted_time_sum_sec")
  adaptedExecutionCount      Int      @default(0) @map("adapted_execution_count")
  // Phase 3.5: generic-capture defense. If this pattern is the matched-by
  // for too many reuses too fast, flag for review and cool off.
  reuseWindowCount           Int      @default(0) @map("reuse_window_count")
  reuseWindowStartedAt       DateTime? @map("reuse_window_started_at")
  cooldownUntil              DateTime? @map("cooldown_until")
  notes                      String?
  reusePotential             String?  @map("reuse_potential")
  futureDistributedStorage   Boolean  @default(true) @map("future_distributed_storage")
  storageUri                 String?  @map("storage_uri")
  contentHash                String?  @map("content_hash")
  status                     String   @default("active")
  createdAt                  DateTime @default(now()) @map("created_at")
  updatedAt                  DateTime @updatedAt @map("updated_at")

  @@index([intentType])
  @@index([status])
  @@map("patterns")
}

model CreditAccount {
  id        String   @id
  ownerId   String   @map("owner_id")
  ownerType String   @map("owner_type") // user | provider | pattern_creator | node | system
  balance   Float    @default(0)
  earned    Float    @default(0)
  spent     Float    @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  events CreditEvent[]

  @@unique([ownerId, ownerType])
  @@map("credit_accounts")
}

model CreditEvent {
  id            String   @id
  accountId     String   @map("account_id")
  amount        Float
  eventType     String   @map("event_type") // intent_submission_debit | capability_reward | pattern_reuse_reward | system_grant | manual_adjustment | pattern_creation_reward | node_storage_reward
  intentId      String?  @map("intent_id")
  patternId     String?  @map("pattern_id")
  capabilityId  String?  @map("capability_id")
  executionId   String?  @map("execution_id")
  nodeId        String?  @map("node_id") // Phase 1: node-side rewards reference the node that earned them
  description   String?
  createdAt     DateTime @default(now()) @map("created_at")

  account CreditAccount @relation(fields: [accountId], references: [id])

  @@index([accountId])
  @@index([eventType])
  @@map("credit_events")
}

// ---------- Phase 1: Node client (storage-only) ----------

model Node {
  id            String   @id // derived from pubkey hash
  pubkey        String   @unique // ed25519 public key (base64)
  ownerContact  String?  @map("owner_contact") // optional human contact for the node operator
  claimedGb     Int      @map("claimed_gb") // self-reported capacity at registration
  provenGb      Float    @default(0) @map("proven_gb") // updated as challenges succeed
  status        String   @default("active") // active | striked | retired
  strikes       Int      @default(0)
  lastSeenAt    DateTime @map("last_seen_at")
  createdAt     DateTime @default(now()) @map("created_at")

  assignments NodeAssignment[]

  @@index([status])
  @@map("nodes")
}

model NodeAssignment {
  id           String    @id
  nodeId       String    @map("node_id")
  patternId    String    @map("pattern_id")
  sha256       String
  sizeBytes    Int       @map("size_bytes")
  status       String    @default("assigned") // assigned | confirmed | failed
  lastChallengeAt DateTime? @map("last_challenge_at")
  challengeFailures Int   @default(0) @map("challenge_failures")
  assignedAt   DateTime  @default(now()) @map("assigned_at")
  confirmedAt  DateTime? @map("confirmed_at")

  node Node @relation(fields: [nodeId], references: [id])

  @@unique([nodeId, patternId])
  @@index([patternId])
  @@index([status])
  @@map("node_assignments")
}

// ---------- Phase 2: compute nodes + work queue ----------

model WorkAssignment {
  id           String   @id
  executionId  String   @unique @map("execution_id")
  executorKind String   @map("executor_kind") // intent_type — what kind of work this is
  nodeId       String?  @map("node_id") // null = unclaimed; "local-fallback" = ran on server after timeout
  status       String   @default("queued") // queued | claimed | running | completed | failed
  inputJson    String   @map("input_json") // serialized minimal ExecutorContext for the runner
  outputJson   String?  @map("output_json")
  outputText   String?  @map("output_text")
  executionMode String? @map("execution_mode") // "fresh" | "adapted" | "placeholder"
  errorText    String?  @map("error_text")
  claimedAt    DateTime? @map("claimed_at")
  completedAt  DateTime? @map("completed_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([status, executorKind])
  @@map("work_assignments")
}
